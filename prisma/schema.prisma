generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(cuid())
  gamertag     String        @unique
  email        String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  sessions UserSession[]
  players  LobbyPlayer[]

  @@map("users")
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("user_sessions")
}

// Lobby stores settings and game state as JSON columns for simplicity.
// settings: { modes: string[], intensity: string, maxPlayers: number }
// game: { round, teamScore, enemyScore, side, currentStrat, rerollsLeft, status }
model Lobby {
  id        String   @id @default(cuid())
  code      String   @unique
  hostId    String   // LobbyPlayer.id of the current host
  settings  Json
  game      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  players LobbyPlayer[]

  @@index([code])
  @@map("lobbies")
}

model LobbyPlayer {
  id        String   @id @default(cuid())
  lobbyId   String
  userId    String?  // Null for guest players
  name      String
  agent     String?
  color     String
  isHost    Boolean  @default(false)
  isReady   Boolean  @default(false)
  deaths    Int      @default(0)
  drinks    Int      @default(0)
  connected Boolean  @default(true)
  joinedAt  DateTime @default(now())

  lobby Lobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id])

  @@unique([lobbyId, name])
  @@index([lobbyId])
  @@map("lobby_players")
}
