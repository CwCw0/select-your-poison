# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                     SELECT YOUR POISON - ENVIRONMENT SETUP                    ║
# ╚══════════════════════════════════════════════════════════════════════════════╝
#
# Copy this file to .env and fill in your values
# Run: cp .env.example .env

# ══════════════════════════════════════════════════════════════════════════════
# STEP 1: DATABASE (PostgreSQL) - REQUIRED
# ══════════════════════════════════════════════════════════════════════════════
#
# Option A: Neon (Recommended - Free tier)
#   1. Go to https://neon.tech and sign up
#   2. Create a new project
#   3. Copy the connection string from the dashboard
#   4. Format: postgresql://user:password@host/database?sslmode=require
#
# Option B: Supabase (Free tier)
#   1. Go to https://supabase.com and create a project
#   2. Go to Settings → Database → Connection string
#   3. Use the "URI" format with your password
#
# Option C: Railway
#   1. Go to https://railway.app and deploy a PostgreSQL database
#   2. Copy the connection string from the variables tab
#
# After setting DATABASE_URL, run: npx prisma db push
#
DATABASE_URL="postgresql://user:password@localhost:5432/selectyourpoison"

# ══════════════════════════════════════════════════════════════════════════════
# STEP 2: AUTH SECRET - REQUIRED
# ══════════════════════════════════════════════════════════════════════════════
#
# Generate a secure secret with: openssl rand -base64 32
# Or use: https://generate-secret.vercel.app/32
#
AUTH_SECRET="your-secret-here-generate-with-openssl"

# Your app URL (no trailing slash)
# Development: http://localhost:3000
# Production: https://yourdomain.com
NEXTAUTH_URL="http://localhost:3000"

# ══════════════════════════════════════════════════════════════════════════════
# STEP 3: DISCORD OAUTH (Optional but recommended)
# ══════════════════════════════════════════════════════════════════════════════
#
# Setup Guide:
#   1. Go to https://discord.com/developers/applications
#   2. Click "New Application" and give it a name (e.g., "Select Your Poison")
#   3. Go to "OAuth2" → "General"
#   4. Copy "Client ID" → paste as AUTH_DISCORD_ID
#   5. Click "Reset Secret" → copy and paste as AUTH_DISCORD_SECRET
#   6. Add Redirects (IMPORTANT!):
#      - Development: http://localhost:3000/api/auth/callback/discord
#      - Production:  https://yourdomain.com/api/auth/callback/discord
#   7. Save Changes
#
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# ══════════════════════════════════════════════════════════════════════════════
# STEP 4: GOOGLE OAUTH (Optional)
# ══════════════════════════════════════════════════════════════════════════════
#
# Setup Guide:
#   1. Go to https://console.cloud.google.com/
#   2. Create a new project or select existing
#   3. Go to "APIs & Services" → "Credentials"
#   4. Click "Create Credentials" → "OAuth client ID"
#   5. Application type: "Web application"
#   6. Add Authorized redirect URIs:
#      - Development: http://localhost:3000/api/auth/callback/google
#      - Production:  https://yourdomain.com/api/auth/callback/google
#   7. Copy "Client ID" → paste as AUTH_GOOGLE_ID
#   8. Copy "Client secret" → paste as AUTH_GOOGLE_SECRET
#
# Note: You may need to configure the OAuth consent screen first
#
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ══════════════════════════════════════════════════════════════════════════════
# OPTIONAL: REDIS (for session caching in production)
# ══════════════════════════════════════════════════════════════════════════════
# REDIS_URL="redis://localhost:6379"

# ══════════════════════════════════════════════════════════════════════════════
# OPTIONAL: ANALYTICS
# ══════════════════════════════════════════════════════════════════════════════
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=""

# ══════════════════════════════════════════════════════════════════════════════
# QUICK START CHECKLIST
# ══════════════════════════════════════════════════════════════════════════════
#
# [ ] 1. Set DATABASE_URL with your PostgreSQL connection string
# [ ] 2. Generate AUTH_SECRET with: openssl rand -base64 32
# [ ] 3. (Optional) Set up Discord OAuth
# [ ] 4. (Optional) Set up Google OAuth
# [ ] 5. Run: npx prisma db push
# [ ] 6. Run: npm run dev
#
